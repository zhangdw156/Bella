# ASSISTANT_API_KEY=
# ASSISTANT_MODEL=
# ASSISTANT_BASE_URL=
# Tool Agent（工具执行）
# TOOL_AGENT_API_KEY=
# TOOL_AGENT_MODEL=
# TOOL_AGENT_BASE_URL=
# Eval Agent（评估轨迹）
# EVAL_API_KEY=
# EVAL_MODEL=
# EVAL_BASE_URL=
