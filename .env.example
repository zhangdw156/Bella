# 复制本文件为 .env 并填写实际值。.env 不会被提交到仓库。
#
# 全局默认（未单独配置的 Agent 会回退使用）：
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=


