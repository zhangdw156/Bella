# 复制本文件为 .env 并填写实际值。.env 不会被提交到仓库。
#
# 全局默认（未单独配置的 Agent 会回退使用）：
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
#
# 在 Bella 中跑 BFCL 时，推荐显式设置 BFCL_PROJECT_ROOT，
# 让 BFCL 的 result/ 与 score/ 目录落在项目下，而不是 .venv/site-packages。
# 例如（请将路径替换为你本机 Bella 项目的绝对路径）：
# BFCL_PROJECT_ROOT=/home/zhang/work/Bella/outputs/bfcl
#
# ── mem0 记忆插件（BELLA_MULTI_TURN_MEMORY_MODE=mem0 时生效）──────────
# 自研 mem0 风格实现：LLM 事实提取 + 向量嵌入 + 余弦相似度检索。
# 记忆为全局共享 + 磁盘持久化（JSONL 格式），跑一次 BFCL 推理时所有
# 条目共享同一份记忆，后面的条目可以利用前面积累的经验。
#
# BELLA_MEM0_STORE_PATH=         # JSONL 存储路径（默认: <项目>/outputs/mem0/store.jsonl）
# BELLA_MEM0_API_KEY=            # OpenAI API Key（留空则回退 OPENAI_API_KEY）
# BELLA_MEM0_BASE_URL=           # 自定义 OpenAI 兼容端点（留空则回退 OPENAI_BASE_URL）
# BELLA_MEM0_LLM_MODEL=          # 事实抽取用 LLM（留空则使用 OPENAI_MODEL）
# BELLA_MEM0_EMBEDDER_MODEL=text-embedding-3-small  # 向量嵌入模型
# BELLA_MEM0_MAX_RESULTS=5       # 每次检索返回的最大记忆条数
# BELLA_MEM0_MAX_CHARS_PER_ITEM=800  # 截断工具输出的字符上限
# BELLA_MEM0_EXTRACT_FACTS=true  # 是否用 LLM 提取事实；false 则直接嵌入原文（更快更省钱）
